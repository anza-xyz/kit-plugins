{
    "name": "kit-plugins-monorepo",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "turbo run build --log-order grouped",
        "lint": "oxlint && prettier --check .",
        "lint:fix": "oxlint --fix && prettier --write .",
        "test": "turbo run test --log-order grouped",
        "publish-packages": "pnpm build && changeset publish"
    },
    "devDependencies": {
        "@changesets/changelog-github": "^0.7.0",
        "@changesets/cli": "^2.31.0",
        "@solana-config/oxc": "^0.1.1",
        "@solana/kit": "^6.9.0",
        "@solana/prettier-config-solana": "0.0.6",
        "@types/node": "^25",
        "agadoo": "^3.0.0",
        "happy-dom": "^20.9.0",
        "oxlint": "^1.63.0",
        "oxlint-tsgolint": "^0.22.1",
        "prettier": "^3.8.3",
        "rimraf": "6.1.3",
        "tsup": "^8.5.1",
        "turbo": "^2.9.12",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5",
        "ws": "^8.20.0"
    },
    "engines": {
        "node": ">=22.0"
    },
    "packageManager": "pnpm@10.15.1",
